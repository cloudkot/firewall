<Window x:Class="Firewall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Универсальный фаервол" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.Resources>
        <!-- Общие кисти -->
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E3E42"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#505053"/>
        <SolidColorBrush x:Key="DataGridHeaderBg" Color="#4B4B4E"/>

        <!-- Стиль для вкладок -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource DataGridHeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
        </Style>

        <!-- Стиль для TextBox, ComboBox, CheckBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="#505053"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="#505053"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>

        <!-- Стиль для трекера OxyPlot (карточка с данными) -->
        <Style TargetType="oxy:TrackerControl">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl x:Name="MainTabControl" Margin="10">
            <!-- Вкладка 1: Панель управления -->
            <TabItem Header="📊 Панель управления">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Кнопки управления -->
                    <Border Grid.Row="0" Background="#2D2D30" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse x:Name="FirewallStatusDot" Width="16" Height="16" Margin="15,0,0,0" Fill="Gray" ToolTip="Фаервол выключен"/>
                            <Button x:Name="EnableFirewallBtn" Content="✅ Включить фаервол" Width="169" Margin="5" Click="EnableFirewall_Click"/>
                            <Button x:Name="DisableFirewallBtn" Content="❌ Отключить фаервол" Width="171" Margin="5" Click="DisableFirewall_Click"/>
                            <Button x:Name="IsolationBtn" Content="🔒 Полная изоляция" Width="158" Margin="5" Click="IsolationMode_Click"/>
                            <Button x:Name="ResetRulesBtn" Content="🔄 Сбросить все правила" Width="186" Margin="5" Click="ResetRules_Click"/>
                        </StackPanel>
                    </Border>
                    <!-- Статистика -->
                    <Border Grid.Row="1" Background="#2D2D30" Padding="15" CornerRadius="8" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Статистика за сегодня" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#3E3E42" Margin="5" Padding="10" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="Заблокировано" FontSize="12" Foreground="#888" TextAlignment="Center"/>
                                        <TextBlock x:Name="BlockedCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#FF5555" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#3E3E42" Margin="5" Padding="10" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="Разрешено" FontSize="12" Foreground="#888" TextAlignment="Center"/>
                                        <TextBlock x:Name="AllowedCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#55FF55" TextAlignment="Center"/>                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#3E3E42" Margin="5" Padding="10" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="Активных правил" FontSize="12" Foreground="#888" TextAlignment="Center"/>
                                        <TextBlock x:Name="RulesCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#FFAA55" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <!-- График скорости -->
                    <Border Grid.Row="2" Background="#2D2D30" Padding="15" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Кнопки и выбор интерфейса -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <TextBlock Text="Интерфейс:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="InterfaceCombo" Width="200" Margin="0,0,10,0" SelectionChanged="InterfaceCombo_SelectionChanged" Foreground="Black"/>
                                <Button x:Name="StartCaptureBtn" Content="▶ Старт" Width="120" Margin="0,0,10,0" Click="StartGraph_Click" Background="#3E3E42" Foreground="White"/>
                                <Button x:Name="StopCaptureBtn" Content="⏸ Стоп" Width="120" Click="StopGraph_Click" Background="#3E3E42" Foreground="White"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Text="Скорость сети (байт/с)" FontSize="14" Foreground="#AAA" Margin="0,0,0,10"/>
                            <oxy:PlotView Grid.Row="2" x:Name="SpeedPlot" Model="{Binding PlotModel}" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Правила -->
            <TabItem Header="📜 Правила">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="AddRuleBtn" Content="➕ Добавить правило" Width="162" Margin="0,0,10,0" Click="AddRule_Click" RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-0.537"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Button.RenderTransform>
                        </Button>
                        <Button x:Name="EditRuleBtn" Content="✏️ Редактировать" Width="138" Margin="0,0,10,0" Click="EditRule_Click"/>
                        <Button x:Name="DeleteRuleBtn" Content="🗑️ Удалить" Width="100" Margin="0,0,10,0" Click="DeleteRule_Click"/>
                        <Button x:Name="ImportRulesBtn" Content="📂 Импорт" Width="100" Margin="0,0,10,0" Click="ImportRules_Click"/>
                        <Button x:Name="ExportRulesBtn" Content="💾 Экспорт" Width="100" Click="ExportRules_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="RulesGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Вкл" Binding="{Binding IsEnabled}" Width="50"/>
                            <DataGridTextColumn Header="Имя правила" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Направление" Binding="{Binding Direction}" Width="100"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="80"/>
                            <DataGridTextColumn Header="Протокол" Binding="{Binding Protocol}" Width="80"/>
                            <DataGridTextColumn Header="Лок. порт" Binding="{Binding LocalPort}" Width="80"/>
                            <DataGridTextColumn Header="Удал. IP" Binding="{Binding RemoteIP}" Width="130"/>
                            <DataGridTextColumn Header="Приложение" Binding="{Binding ApplicationPath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StatusBar Grid.Row="2" Background="#2D2D30" Margin="0,10,0,0">
                        <StatusBarItem>
                            <TextBlock x:Name="RulesStatus" Text="Правил: 0"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Активные подключения -->
            <TabItem Header="🌐 Активные подключения">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="RefreshConnectionsBtn" Content="🔄 Обновить" Width="120" Margin="0,0,10,0" Click="RefreshConnections_Click"/>
                        <CheckBox x:Name="AutoRefreshCheck" Content="Автообновление" IsChecked="True" Margin="0,0,10,0"/>
                    </StackPanel>
                    <DataGrid x:Name="ConnectionsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                              VirtualizingPanel.IsVirtualizing="True" 
                              AlternatingRowBackground="#2D2D30">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Протокол" Binding="{Binding Protocol}" Width="80"/>
                            <DataGridTextColumn Header="Локальный адрес" Binding="{Binding LocalAddress}" Width="200"/>
                            <DataGridTextColumn Header="Удалённый адрес" Binding="{Binding RemoteAddress}" Width="200"/>
                            <DataGridTextColumn Header="Состояние" Binding="{Binding State}" Width="120"/>
                            <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="60"/>
                            <DataGridTextColumn Header="Процесс" Binding="{Binding ProcessName}" Width="*"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Заблокировать это приложение" Click="BlockAppFromConnection_Click"/>
                                <MenuItem Header="Заблокировать этот удалённый IP" Click="BlockIPFromConnection_Click"/>
                                <MenuItem Header="Временно заблокировать приложение" Click="TemporaryBlockApp_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    <StatusBar Grid.Row="2" Background="#2D2D30" Margin="0,10,0,0">
                        <StatusBarItem>
                            <TextBlock x:Name="ConnectionsStatus" Text="Соединений: 0"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Логи -->
            <TabItem Header="📋 Логи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="LogSearchBox" Width="200" Margin="0,0,10,0" Text="Поиск..."/>
                        <ComboBox x:Name="LogTypeCombo" Width="150" Margin="0,0,10,0" SelectedIndex="0" SelectionChanged="LogTypeCombo_SelectionChanged" Foreground="Black">
                            <ComboBoxItem Content="Сетевые события"/>
                            <ComboBoxItem Content="Журнал приложения"/>
                        </ComboBox>
                        <Button x:Name="ExportLogsBtn" Content="📎 Экспорт" Width="100" Margin="0,0,10,0" Click="ExportLogs_Click"/>
                        <Button x:Name="ClearLogsBtn" Content="🧹 Очистить логи" Width="120" Click="ClearLogs_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="LogsGrid" Grid.Row="2" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding Time}" Width="150"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding EventType}" Width="120"/>
                            <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*"/>
                            <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="130"/>
                            <DataGridTextColumn Header="Приложение" Binding="{Binding ApplicationPath}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StatusBar Grid.Row="3" Background="#2D2D30" Margin="0,10,0,0">
                        <StatusBarItem>
                            <TextBlock x:Name="LogsStatus" Text="Записей: 0"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- Вкладка 5: Настройки -->
            <TabItem Header="⚙️ Настройки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <GroupBox Header="Общие" Grid.Row="0" Margin="0,0,0,15" Background="#2D2D30">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="AutoStartCheck" Content="Автозапуск с Windows" Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Уведомления" Grid.Row="1" Margin="0,0,0,15" Background="#2D2D30">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="ShowNotificationsCheck" Content="Показывать всплывающие уведомления" Margin="0,5"/>
                            <CheckBox x:Name="PlaySoundCheck" Content="Звук при блокировке" Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Резервное копирование" Grid.Row="3" Margin="0,0,0,15" Background="#2D2D30">
                        <StackPanel Margin="10" Orientation="Horizontal">
                            <Button x:Name="BackupConfigBtn" Content="💾 Резервная копия" Width="150" Margin="0,0,10,0" Click="BackupConfig_Click"/>
                            <Button x:Name="RestoreConfigBtn" Content="🔄 Восстановить" Width="150" Click="RestoreConfig_Click"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Безопасность" Grid.Row="2" Margin="0,0,0,15" Background="#2D2D30">
                        <StackPanel Margin="10">
                            <CheckBox x:Name="EnablePasswordCheck" Content="Требовать пароль при запуске" Margin="0,5"/>
                            <Button x:Name="ChangePasswordBtn" Content="Сменить пароль" Width="150" Margin="0,5" Click="ChangePassword_Click" IsEnabled="False"/>
                        </StackPanel>
                    </GroupBox>
                    
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>