<Window x:Class="Firewall.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Временная блокировка" Height="180" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#2D2D30">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Введите время блокировки (минут):" Foreground="White" Margin="0,0,0,10"/>
        <TextBox x:Name="MinutesBox" Grid.Row="1" Text="5" Background="#3E3E42" Foreground="White" Margin="0,0,0,15"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Отмена" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>