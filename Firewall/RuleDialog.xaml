<Window x:Class="Firewall.RuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Правило" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D30" ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E3E42"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#505053"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="#505053"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="#505053"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="5,5,5,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Имя правила:"/>
        <TextBox x:Name="tbName" Grid.Row="1"/>

        <TextBlock Grid.Row="2" Text="Направление:"/>
        <ComboBox x:Name="cbDirection" Grid.Row="3" SelectedIndex="0" Foreground="Black">
            <ComboBoxItem Content="Исходящий"/>
            <ComboBoxItem Content="Входящий"/>
            <ComboBoxItem Content="Оба"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Text="Действие:"/>
        <ComboBox x:Name="cbAction" Grid.Row="5" SelectedIndex="0" Foreground="Black">
            <ComboBoxItem Content="Блок"/>
            <ComboBoxItem Content="Разрешить"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Text="Протокол:"/>
        <ComboBox x:Name="cbProtocol" Grid.Row="7" SelectedIndex="0" Foreground="Black">
            <ComboBoxItem Content="TCP"/>
            <ComboBoxItem Content="UDP"/>
            <ComboBoxItem Content="ICMP"/>
        </ComboBox>

        <TextBlock Grid.Row="8" Text="Локальный порт (или 'Все'):"/>
        <TextBox x:Name="tbLocalPort" Grid.Row="9" Text="Все"/>

        <TextBlock Grid.Row="10" Text="Удалённый IP (или 'Любой'):"/>
        <TextBox x:Name="tbRemoteIP" Grid.Row="11" Text="Любой"/>

        <TextBlock Grid.Row="12" Text="Приложение (путь к .exe):"/>
        <StackPanel Grid.Row="13" Orientation="Horizontal">
            <TextBox x:Name="tbAppPath" Width="300" Margin="0,0,10,0"/>
            <Button x:Name="btnBrowse" Content="Обзор..." Width="80" Click="Browse_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="14" Text="Время действия:"/>
        <ComboBox x:Name="cbTimeAction" Grid.Row="15" SelectedIndex="0" Foreground="Black">
            <ComboBoxItem Content="Постоянно"/>
            <ComboBoxItem Content="На сеанс (до перезагрузки)"/>
            <ComboBoxItem Content="На 1 час"/>
            <ComboBoxItem Content="На 5 минут"/>
            <ComboBoxItem Content="На 15 минут"/>
        </ComboBox>

        <CheckBox x:Name="chkEnabled" Grid.Row="16" Content="Правило активно" IsChecked="True"/>

        <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,10">
            <Button x:Name="btnOk" Content="OK" Width="80" Margin="0,0,10,0" Click="Ok_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="80" Margin="0,0,10,0" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>